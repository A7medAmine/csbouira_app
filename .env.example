# CS Bouira App — Environment Variables
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.

# Supabase (get these from your Supabase project dashboard)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Google Sign-In — Web client ID from Google Cloud Console
# Required for native Google Sign-In to work with Supabase.
# See docs/google_signin_setup.md for details.
GOOGLE_SERVER_CLIENT_ID=TODO_INSERT_YOUR_WEB_CLIENT_ID.apps.googleusercontent.com

# Google Sign-In — Android client ID (optional, but required on Android
# if google-services.json is not present in android/app/).
# Get this from Google Cloud Console → APIs & Services → Credentials
# → OAuth 2.0 Client IDs → Android type.
# GOOGLE_ANDROID_CLIENT_ID=XXXXXXXXXXXX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
